{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:definitelyTyped"
  ],
  "packageRules": [
    {
      "description": "Group minor, patch, and pin updates for production dependencies",
      "groupName": "dependencies (non-major)",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Group minor, patch, and pin updates for dev dependencies",
      "matchManagers": ["npm"],
      "groupName": "devDependencies (non-major)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Automerge non-major GitHub Actions updates after a waiting period",
      "groupName": "github-actions (non-major)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    }
  ]
}
