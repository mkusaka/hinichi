{
  "name": "hinichi",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --config vite.client.config.ts",
    "build": "$npm_execpath run build:client && vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.0",
    "@hono/zod-validator": "^0.8.0",
    "ai": "^7.0.0",
    "feed": "^5.2.0",
    "gsap": "^3.14.2",
    "hono": "^4.11.9",
    "three": "^0.185.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.4",
    "@cloudflare/vitest-pool-workers": "0.17.0",
    "@cloudflare/workers-types": "4.20260702.1",
    "@vitest/runner": "4.1.9",
    "@vitest/snapshot": "4.1.9",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "wrangler": "4.106.0"
  }
}
