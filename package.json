{
  "name": "hinichi",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --config vite.client.config.ts",
    "build": "$npm_execpath run build:client && vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.24",
    "@hono/zod-validator": "^0.7.6",
    "ai": "^6.0.79",
    "feed": "^5.2.0",
    "gsap": "^3.14.2",
    "hono": "^4.11.9",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.27.0",
    "@cloudflare/vitest-pool-workers": "0.12.21",
    "@cloudflare/workers-types": "4.20260312.1",
    "@vitest/runner": "3.2.4",
    "@vitest/snapshot": "3.2.4",
    "oxfmt": "0.39.0",
    "oxlint": "1.54.0",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "3.2.4",
    "wrangler": "4.72.0"
  }
}
